# Cursor indexing — AutoTagger repo
# Goal: keep agents focused on v5 + docs; skip generated clones and bulk artifacts.

# Generated outputs and large run folders
output/
**/output/
**/logs/
**/reports/

# Large local-only workspace clone (gitignored)
v6-workspace/

# Root archives (also gitignored; still skip for IDE context)
*.zip

# Secrets and OS noise
.DS_Store
.env
.env.*

# Python / Node noise (if present under any workspace)
**/__pycache__/
**/node_modules/
**/venv/
**/.venv/

# Optional — uncomment to shrink index when you are not editing legacy trees:
# v1-original-kb/
# v2-engine/
# v3-dev/
# v4-workspace/

# Optional — if n8n_workflows grows very large and you want Cursor to skip JSON here,
# uncomment (normally keep indexed; trees are real copies in git):
# n8n_workflows/premium/
# n8n_workflows/workflows/
